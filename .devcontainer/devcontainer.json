{
  "name": "csci5103-project3",
  // "image": "ghcr.io/astral-sh/uv:debian-slim",
  "image": "python:3.12-slim",
  "runArgs": ["--add-host=host.docker.internal:host-gateway"],
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers-extra/features/uv:1": {},
  },
  // "postCreateCommand": "pip install uv && export UV_PROJECT_ENVIRONMENT=/usr/local && uv python pin --global 3.12 && uv pip install --system -r requirements.txt",
  "postCreateCommand": "uv python pin --global 3.12 && uv pip install --system -r requirements.txt",
  
  "remoteEnv": {
    "WORKSPACE_FOLDER": "${containerWorkspaceFolder}"
  },

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "DrBlury.protobuf-vsc",
        "bierner.markdown-mermaid",
        "jeff-hykin.better-dockerfile-syntax"
      ]
    }
  },
  "containerEnv": {
    "PYTHONPATH": "$PYTHONPATH:${containerWorkspaceFolder}:${containerWorkspaceFolder}/proto/src",
    "TARGET" : "host.docker.internal:50051"
  }
}
